#!/bin/bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: herdr-tdlm [options] [ai-command] [second-ai-command]

Create/focus one Herdr workspace for the base dir with one tdl tab per direct
subdirectory. This mirrors tmux tdlm's "one session, one window per project"
shape using Herdr workspace + tabs.

Options:
  -s, --session NAME    Herdr session to use (default: default)
  -w, --workspace NAME  Workspace label to create/focus (default: base dir name)
  -C, --dir PATH        Base directory whose direct subdirectories become tabs
      --reset           Recreate the matching workspace
      --no-attach       Bootstrap/focus only; print attach command instead of opening Herdr
  -h, --help            Show this help

Examples:
  herdr-tdlm
  herdr-tdlm cx
  herdr-tdlm cx codex
  herdr-tdlm --workspace omarchy --reset
EOF
}

sanitize_name() {
  local raw safe
  raw=$1
  safe=$(printf '%s' "$raw" | tr '.:' '--' | sed 's/[^[:alnum:]_-]/-/g; s/--*/-/g; s/^-//; s/-$//')
  printf '%s' "${safe:-dev}"
}

require_command() {
  local command_name
  command_name=$1

  if ! command -v "$command_name" >/dev/null 2>&1; then
    echo "herdr-tdlm: missing required command: $command_name" >&2
    exit 1
  fi
}

herdr_session() {
  if [[ $session == "default" ]]; then
    herdr "$@"
  else
    herdr --session "$session" "$@"
  fi
}

attach_command() {
  if [[ $session == "default" ]]; then
    printf 'herdr'
  else
    printf 'herdr --session %q' "$session"
  fi
}

is_session_running() {
  herdr session list --json | jq -e --arg name "$session" '
    .sessions[]? | select(.name == $name and .running == true)
  ' >/dev/null
}

wait_for_session() {
  local attempts
  attempts=0

  until herdr_session workspace list >/dev/null 2>&1; do
    if (( attempts >= 100 )); then
      echo "herdr-tdlm: timed out waiting for Herdr session '$session'" >&2
      if [[ -r $log_file ]]; then
        echo "--- $log_file ---" >&2
        tail -40 "$log_file" >&2 || true
      fi
      exit 1
    fi

    attempts=$((attempts + 1))
    sleep 0.1
  done
}

start_session_if_needed() {
  local -a command

  if is_session_running; then
    return 0
  fi

  echo "Starting Herdr session '$session'..." >&2
  command=(herdr)
  if [[ $session != "default" ]]; then
    command+=(--session "$session")
  fi
  command+=(server)

  nohup "${command[@]}" >"$log_file" 2>&1 &
  wait_for_session
}

version_at_least() {
  local version minimum index current required
  local -a version_parts minimum_parts
  version=${1#v}
  minimum=${2#v}

  IFS=. read -r -a version_parts <<<"$version"
  IFS=. read -r -a minimum_parts <<<"$minimum"

  for index in 0 1 2; do
    current=${version_parts[$index]:-0}
    required=${minimum_parts[$index]:-0}
    current=${current%%[^0-9]*}
    required=${required%%[^0-9]*}
    current=${current:-0}
    required=${required:-0}

    if (( current > required )); then
      return 0
    elif (( current < required )); then
      return 1
    fi
  done

  return 0
}

detect_herdr_capabilities() {
  local server_version

  if herdr pane --help 2>&1 | grep -q -- '--ratio'; then
    herdr_cli_supports_split_ratio=true
  fi

  server_version=$(herdr_session status server 2>/dev/null | awk '/^version:/ { print $2; exit }')
  if [[ -n $server_version ]] && version_at_least "$server_version" "0.6.10"; then
    herdr_server_supports_split_ratio=true
  fi

  if [[ $herdr_cli_supports_split_ratio == "true" && $herdr_server_supports_split_ratio == "true" ]]; then
    herdr_supports_split_ratio=true
  fi
}

warn_if_ratio_unsupported() {
  if [[ $herdr_supports_split_ratio == "true" ]]; then
    return 0
  fi

  if [[ $herdr_cli_supports_split_ratio != "true" ]]; then
    echo "herdr-tdlm: $(herdr --version) does not support 'pane split --ratio'; using 50/50 splits." >&2
  elif [[ $herdr_server_supports_split_ratio != "true" ]]; then
    echo "herdr-tdlm: the Herdr CLI supports --ratio, but the running '$session' server does not; using 50/50 splits." >&2
  fi
}

find_workspace_id() {
  herdr_session workspace list | jq -r --arg label "$workspace_label" '
    first(.result.workspaces[]? | select(.label == $label) | .workspace_id) // ""
  '
}

find_tab_id() {
  local label
  label=$1

  [[ -n ${workspace_id:-} ]] || return 0
  herdr_session tab list --workspace "$workspace_id" | jq -r --arg label "$label" '
    first(.result.tabs[]? | select(.label == $label) | .tab_id) // ""
  '
}

close_existing_workspace() {
  local existing_workspace_id
  existing_workspace_id=$(find_workspace_id)

  if [[ -n $existing_workspace_id ]]; then
    echo "Closing existing Herdr workspace '$workspace_label' in session '$session'..." >&2
    herdr_session workspace close "$existing_workspace_id" >/dev/null
  fi
}

split_pane() {
  local target direction ratio cwd
  local -a args
  target=$1
  direction=$2
  cwd=$3
  ratio=${4:-}

  args=(pane split "$target" --direction "$direction" --cwd "$cwd" --no-focus)

  if [[ $herdr_supports_split_ratio == "true" && -n $ratio ]]; then
    args+=(--ratio "$ratio")
  fi

  herdr_session "${args[@]}" | jq -r '.result.pane.pane_id'
}

run_in_pane() {
  local pane_id command_text
  pane_id=$1
  command_text=$2

  [[ -n $command_text ]] || return 0
  herdr_session pane run "$pane_id" "$command_text"
}

rename_pane() {
  local pane_id label
  pane_id=$1
  label=$2

  herdr_session pane rename "$pane_id" "$label" >/dev/null || true
}

editor_command() {
  printf '%s .' "${HERDR_DEV_EDITOR:-${EDITOR:-nvim}}"
}

default_ai_command() {
  printf '%s' "${HERDR_DEV_AI_COMMAND:-omarchy-launch-ai --path .}"
}

bootstrap_tdl_in_tab() {
  local dir label editor_pane terminal_pane ai_pane ai2_pane
  dir=$1
  label=$2
  editor_pane=$3

  terminal_pane=$(split_pane "$editor_pane" down "$dir" "${HERDR_DEV_EDITOR_TERMINAL_RATIO:-0.85}")
  ai_pane=$(split_pane "$editor_pane" right "$dir" "${HERDR_DEV_EDITOR_AI_RATIO:-0.70}")

  rename_pane "$editor_pane" editor
  rename_pane "$terminal_pane" terminal
  rename_pane "$ai_pane" "$ai_command"

  if [[ -n $second_ai_command ]]; then
    ai2_pane=$(split_pane "$ai_pane" down "$dir" "${HERDR_DEV_AI_STACK_RATIO:-0.50}")
    rename_pane "$ai2_pane" "$second_ai_command"
    run_in_pane "$ai2_pane" "$second_ai_command"
  fi

  run_in_pane "$ai_pane" "$ai_command"
  run_in_pane "$editor_pane" "$(editor_command)"
  echo "  ✓ $label"
}

create_workspace_for_first_dir() {
  local dir label json tab_id root_pane
  dir=$1
  label=$2

  echo "Creating Herdr workspace '$workspace_label'..." >&2
  json=$(herdr_session workspace create --cwd "$dir" --label "$workspace_label" --focus)
  workspace_id=$(jq -r '.result.workspace.workspace_id' <<<"$json")
  tab_id=$(jq -r '.result.tab.tab_id' <<<"$json")
  root_pane=$(jq -r '.result.root_pane.pane_id' <<<"$json")

  herdr_session tab rename "$tab_id" "$label" >/dev/null || true
  first_tab_id=$tab_id
  bootstrap_tdl_in_tab "$dir" "$label" "$root_pane"
}

create_tab_for_dir() {
  local dir label existing_tab_id json tab_id root_pane
  dir=$1
  label=$2

  existing_tab_id=$(find_tab_id "$label")
  if [[ -n $existing_tab_id ]]; then
    [[ -n $first_tab_id ]] || first_tab_id=$existing_tab_id
    echo "  ✓ $label already exists"
    return 0
  fi

  json=$(herdr_session tab create --workspace "$workspace_id" --cwd "$dir" --label "$label" --no-focus)
  tab_id=$(jq -r '.result.tab.tab_id' <<<"$json")
  root_pane=$(jq -r '.result.root_pane.pane_id' <<<"$json")

  [[ -n $first_tab_id ]] || first_tab_id=$tab_id
  bootstrap_tdl_in_tab "$dir" "$label" "$root_pane"
}

session="${HERDR_DEV_SESSION:-default}"
workspace_label="${HERDR_DEV_WORKSPACE:-}"
base_dir=$PWD
reset=false
attach=true
herdr_cli_supports_split_ratio=false
herdr_server_supports_split_ratio=false
herdr_supports_split_ratio=false
workspace_id=
first_tab_id=

while (( $# > 0 )); do
  case $1 in
    -s|--session)
      [[ -n ${2:-} ]] || { echo "herdr-tdlm: --session requires a value" >&2; exit 1; }
      session=$2
      shift 2
      ;;
    -w|--workspace)
      [[ -n ${2:-} ]] || { echo "herdr-tdlm: --workspace requires a value" >&2; exit 1; }
      workspace_label=$2
      shift 2
      ;;
    -C|--dir)
      [[ -n ${2:-} ]] || { echo "herdr-tdlm: --dir requires a value" >&2; exit 1; }
      base_dir=$2
      shift 2
      ;;
    --reset)
      reset=true
      shift
      ;;
    --no-attach)
      attach=false
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -* )
      echo "herdr-tdlm: unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      break
      ;;
  esac
done

if (( $# > 2 )); then
  usage >&2
  exit 1
fi

require_command herdr
require_command jq

if [[ ! -d $base_dir ]]; then
  echo "herdr-tdlm: base directory does not exist: $base_dir" >&2
  exit 1
fi

base_dir=$(cd "$base_dir" && pwd)
[[ -n $workspace_label ]] || workspace_label=$(basename "$base_dir")
ai_command=${1:-$(default_ai_command)}
second_ai_command=${2:-}

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/herdr-dev"
mkdir -p "$state_dir"
log_file="$state_dir/$(sanitize_name "$session").log"

start_session_if_needed
detect_herdr_capabilities
warn_if_ratio_unsupported

if [[ $reset == "true" ]]; then
  close_existing_workspace
fi

workspace_id=$(find_workspace_id)
created_count=0

shopt -s nullglob
for dir in "$base_dir"/*/; do
  [[ -d $dir ]] || continue
  dir=${dir%/}
  label=$(basename "$dir")

  if [[ -z $workspace_id ]]; then
    create_workspace_for_first_dir "$dir" "$label"
  else
    create_tab_for_dir "$dir" "$label"
  fi

  created_count=$((created_count + 1))
done

if (( created_count == 0 )); then
  echo "herdr-tdlm: no direct subdirectories under $base_dir" >&2
  exit 1
fi

if [[ -n $workspace_id ]]; then
  herdr_session workspace focus "$workspace_id" >/dev/null
fi
if [[ -n $first_tab_id ]]; then
  herdr_session tab focus "$first_tab_id" >/dev/null || true
fi

if [[ $attach != "true" ]]; then
  echo "Ready: $(attach_command)"
  exit 0
fi

if [[ -n ${HERDR_ENV:-} && ${HERDR_DEV_NESTED_ATTACH:-} != "1" ]]; then
  # The workspace/tab focus above is enough for an existing Herdr client.
  exit 0
fi

if [[ $session == "default" ]]; then
  exec herdr
else
  exec herdr --session "$session"
fi
