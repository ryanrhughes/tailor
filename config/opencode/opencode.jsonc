{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@franlol/opencode-md-table-formatter@0.0.3"],
  "mcp": {
    // Heavier MCPs default to disabled — they load their full tool catalog into
    // the agent's context every turn. Toggle on per-session via `"enabled": true`
    // (or use a project-local opencode.jsonc override).
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "oauth": {},
      "enabled": false
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "chrome-devtools-mcp@latest", "--isolated=true", "--channel=canary", "--headless=true"],
      "enabled": false
    },
    // Lightweight remote MCPs stay on — tiny tool surface, useful most of the time.
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    }
  }
}
